# Descriptive contact for the ESI/Fuzzwork User-Agent (ESI etiquette).
ESI_CONTACT=you@example.com

# --- EVE SSO (Phase 4, optional personalization) ---
# Register an app at https://developers.eveonline.com/
#   Callback URL: <site>/api/auth/callback  (e.g. http://localhost:3000/api/auth/callback)
#   Scopes:       esi-skills.read_skills.v1  esi-wallet.read_character_wallet.v1
EVE_CLIENT_ID=
EVE_CLIENT_SECRET=
# Random 32+ byte secret for encrypting the session cookie, e.g. `openssl rand -hex 32`
SESSION_SECRET=
# Public base URL of the site (used to build the OAuth redirect_uri).
# Local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
